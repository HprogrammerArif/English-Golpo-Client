# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Your backend base URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://your-api.example.com

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Get these from https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Leave EXPO_PUBLIC_SENTRY_DSN blank to disable Sentry entirely.
# Get DSN from https://sentry.io → Project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=

# SENTRY_AUTH_TOKEN is build-time only (for source maps upload). Never use EXPO_PUBLIC_ prefix here.
# Get from https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=

# ── Push Notifications ────────────────────────────────────────────────────────
# Your Expo project ID (from app.json or expo.dev dashboard)
# Used for registering push notification tokens
EXPO_PUBLIC_PROJECT_ID=
